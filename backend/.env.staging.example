DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME
SECRET_KEY=replace-with-very-long-random-secret
BASE_URL=https://staging.yourdomain.com
ENVIRONMENT=staging
LOG_LEVEL=INFO

SENDGRID_API_KEY=SG.xxxxx
FROM_EMAIL=noreply@yourdomain.com

# Frontend allowed origins
CORS_ORIGINS=https://staging.yourdomain.com

# Optional: media object storage
MEDIA_STORAGE_BACKEND=s3
S3_ENDPOINT_URL=https://<provider-endpoint>
S3_REGION=us-east-1
S3_BUCKET=your-staging-bucket
S3_ACCESS_KEY_ID=your-key
S3_SECRET_ACCESS_KEY=your-secret
S3_PUBLIC_BASE_URL=https://cdn-staging.yourdomain.com
S3_PREFIX=staging/uploads
S3_OBJECT_ACL=public-read

# Optional: billing / captcha / maps
STRIPE_SECRET_KEY=sk_test_or_live
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_BASIC=price_xxx
STRIPE_PRICE_PREMIUM=price_xxx
HCAPTCHA_SECRET=xxx
GOOGLE_MAPS_API_KEY=xxx
